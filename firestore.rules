rules_version = '2';

// Firestore 보안 규칙.
//   - 모든 클라이언트가 question_stats 를 read 가능 (전체 통계 표시용).
//   - write 는 익명 로그인 사용자에게만 허용.
//   - 필드는 attempts / correct / option_counts / last_updated_at 4개로 제한.
//   - delete 는 어떤 경우에도 불허.
//
// NOTE: "카운터 +1 증가만 허용" 같은 세밀한 검증은 serverTimestamp 비교와
//       dotted-path 처리의 미묘함 때문에 안정적으로 표현하기 어려워
//       MVP 단계에서는 제거했다. 위조 카운트 폭증 방어는 App Check 활성화로
//       대체할 예정 (Firebase 콘솔 > App Check).
service cloud.firestore {
  match /databases/{database}/documents {

    match /question_stats/{qid} {
      allow read: if true;

      allow create, update: if
        request.auth != null
        && request.resource.data.keys().hasOnly(
             ['attempts', 'correct', 'option_counts', 'last_updated_at']);

      allow delete: if false;
    }
  }
}
